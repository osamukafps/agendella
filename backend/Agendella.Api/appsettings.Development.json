{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=agendella_dev;Username=agendella;Password=agendella"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:4200"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "Jwt": {
    "Issuer": "Agendella.Dev",
    "Audience": "Agendella.Frontend.Dev",
    "AccessTokenMinutes": 15,
    "PrivateKeyPath": "keys/dev/jwt-private.pem",
    "PublicKeyPath": "keys/dev/jwt-public.pem"
  },
  "RefreshCookie": {
    "Name": "agendella_rt",
    "Domain": "localhost",
    "Path": "/auth",
    "Secure": false,
    "SameSite": "Strict",
    "HttpOnly": true,
    "DurationDays": 14
  },
  "RateLimiting": {
    "LoginPerIpPerMinute": 5,
    "LoginPerIpAndEmailPerHour": 10,
    "RefreshPerIpPerMinute": 30,
    "AuthenticatedPerCollaboratorPerMinute": 120
  },
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
